{
  "name": "quasar-telegram-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--require=./scripts/crypto-hash-polyfill.cjs quasar dev",
    "dev:e2e": "NODE_OPTIONS=--require=./scripts/crypto-hash-polyfill.cjs quasar dev --port 4100 --hostname 127.0.0.1",
    "build": "NODE_OPTIONS=--require=./scripts/crypto-hash-polyfill.cjs quasar build",
    "format": "biome format --write",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false",
    "lint": "biome lint",
    "lint:dead-code": "biome lint --only=lint/correctness/noUnusedImports --only=lint/correctness/noUnusedVariables",
    "lint:fix": "biome check --write",
    "quality:all": "npm run format && npm run lint:fix && npm run format:check && npm run lint:dead-code && npm run lint",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "node ./scripts/run-e2e-local.cjs"
  },
  "dependencies": {
    "@nostr-dev-kit/ndk": "^3.0.0",
    "@quasar/extras": "^1.17.0",
    "pinia": "^2.1.7",
    "quasar": "^2.17.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@quasar/app-vite": "2.1.0",
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "~5.7.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=8.0.0",
    "yarn": ">=1.21.1"
  }
}
