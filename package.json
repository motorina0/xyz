{
  "name": "nostr-chat",
  "productName": "Nostr Chat",
  "version": "0.2.0",
  "description": "Desktop and web Nostr chat client.",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/quasar.cjs dev",
    "dev:e2e": "node ./scripts/quasar.cjs dev --port 4100 --hostname 127.0.0.1",
    "dev:electron": "node ./scripts/quasar.cjs dev -m electron",
    "dev:android": "node ./scripts/quasar.cjs dev -m capacitor -T android",
    "build": "node ./scripts/quasar.cjs build",
    "preview:spa": "node ./scripts/preview-spa.cjs",
    "build:android:sync": "node ./scripts/build-android-docker.cjs sync",
    "build:android:apk:debug": "node ./scripts/build-android-docker.cjs apk-debug",
    "build:android:apk:release": "node ./scripts/build-android-docker.cjs apk-release",
    "build:android:aab:release": "node ./scripts/build-android-docker.cjs aab-release",
    "build:android:release": "node ./scripts/build-android-docker.cjs all-release",
    "build:android:local:sync": "node ./scripts/build-android.cjs sync",
    "build:android:local:apk:debug": "node ./scripts/build-android.cjs apk-debug",
    "build:android:local:apk:release": "node ./scripts/build-android.cjs apk-release",
    "build:android:local:aab:release": "node ./scripts/build-android.cjs aab-release",
    "build:android:local:release": "node ./scripts/build-android.cjs all-release",
    "build:electron": "node ./scripts/quasar.cjs build -m electron -b builder --publish never",
    "build:electron:dir": "node ./scripts/quasar.cjs build -m electron -b builder -s --publish never",
    "build:electron:mac": "node ./scripts/quasar.cjs build -m electron -b builder -T mac --publish never",
    "build:electron:win": "node ./scripts/quasar.cjs build -m electron -b builder -T win --publish never",
    "build:electron:linux": "node ./scripts/quasar.cjs build -m electron -b builder -T linux --publish never",
    "version:bump": "node ./scripts/bump-version.cjs",
    "format": "biome format --write",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false",
    "lint": "biome lint",
    "lint:dead-code": "biome lint --only=lint/correctness/noUnusedImports --only=lint/correctness/noUnusedVariables",
    "lint:fix": "biome check --write --unsafe --max-diagnostics=100",
    "quality:web": "npm run format && npm run lint:fix && npm run format:check && npm run lint:dead-code && npm run lint && npm run typecheck",
    "quality:capacitor": "node ./scripts/run-subproject-quality.cjs src-capacitor",
    "quality:cordova": "node ./scripts/run-subproject-quality.cjs src-cordova",
    "quality:push-gateway": "node ./scripts/run-subproject-quality.cjs services/push-gateway",
    "quality:all": "npm run quality:web && npm run quality:capacitor && npm run quality:cordova && npm run quality:push-gateway",
    "prepare:quasar": "node ./scripts/quasar.cjs prepare",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:auth-smoke": "playwright test e2e/auth.spec.ts",
    "test:e2e:contacts-smoke": "playwright test e2e/contacts.spec.ts",
    "test:e2e:dm-smoke": "playwright test e2e/dm",
    "test:e2e:groups-smoke": "playwright test e2e/groups",
    "test:e2e:relays-smoke": "playwright test e2e/relays.spec.ts",
    "test:e2e:session-smoke": "playwright test e2e/session.spec.ts",
    "test:e2e:local": "node ./scripts/run-e2e-local.cjs",
    "test:e2e:local:auth-smoke": "node ./scripts/run-e2e-local.cjs e2e/auth.spec.ts",
    "test:e2e:local:contacts-smoke": "node ./scripts/run-e2e-local.cjs e2e/contacts.spec.ts",
    "test:e2e:local:dm-smoke": "node ./scripts/run-e2e-local.cjs e2e/dm",
    "test:e2e:local:groups-smoke": "node ./scripts/run-e2e-local.cjs e2e/groups",
    "test:e2e:local:relays-smoke": "node ./scripts/run-e2e-local.cjs e2e/relays.spec.ts",
    "test:e2e:local:session-smoke": "node ./scripts/run-e2e-local.cjs e2e/session.spec.ts"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@nostr-dev-kit/ndk": "^3.0.3",
    "@quasar/extras": "^1.18.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "quasar": "^2.19.3",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@quasar/app-vite": "2.6.0",
    "@types/node": "^24.12.4",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.6",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.3.0"
  },
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12",
    "yarn": ">=1.21.1"
  }
}
